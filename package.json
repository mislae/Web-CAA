{
  "name": "caa-brs-portal",
  "version": "2.0.0",
  "description": "Portal público del Centro de Alumnos BRS",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node -e \"console.log('Sin pruebas automatizadas configuradas')\"",
    "lint": "node --check server.js && node --check service-worker.js",
    "proposals:replay": "node scripts/replay-proposals-inbox.js",
    "proposals:replay:dry": "node scripts/replay-proposals-inbox.js --dry-run",
    "build:css": "tailwindcss -i css/input.css -o css/tailwind.css --minify",
    "watch:css": "tailwindcss -i css/input.css -o css/tailwind.css --watch"
  },
  "keywords": [
    "CAA",
    "BRS",
    "Portal",
    "Portal Escolar",
    "Comunidad"
  ],
  "author": "CAA BRS",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
